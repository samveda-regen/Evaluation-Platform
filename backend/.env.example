# Database Configuration
# PostgreSQL connection string format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/test_platform"

# JWT Secret Keys (change these in production!)
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:5173"
# Optional explicit candidate app URL used in invitation emails.
# Set this when FRONTEND_URL points to an admin-specific path/domain.
# Example: CANDIDATE_FRONTEND_URL="https://example.com"
# CANDIDATE_FRONTEND_URL=

# Email provider for invitation emails: auto | smtp
MAIL_PROVIDER=smtp

# SMTP configuration for invitation emails
# Optional provider hint (useful for Zoho-specific defaults/error hints)
# SMTP_PROVIDER=zoho
