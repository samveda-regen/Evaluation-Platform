DATABASE_URL="postgresql://samveda@localhost:5432/test_platform"


# JWT Secret Keys (change these in production!)
JWT_SECRET="your-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL for CORS
#FRONTEND_URL="http://localhost:5173"
FRONTEND_URL="https://unpreaching-unaugmentative-raelynn.ngrok-free.dev"

# ==================== FILE STORAGE ====================
# Storage backend: "database" (PostgreSQL blobs) or "filesystem" (local disk files)
FILE_STORAGE_MODE="filesystem"
# Local path used when FILE_STORAGE_MODE=filesystem
FILE_STORAGE_PATH="./storage"
CANDIDATE_DATA_DIR_NAME="Candidate Data"
QUESTION_BANK_DIR_NAME="Question Bank"
# Files (snapshots, recordings, MCQ media, ID documents) can now be stored locally.

# Audio violation thresholds (0-255, WebAudio average level)
AUDIO_WARNING_LEVEL=42
AUDIO_CRITICAL_LEVEL=58
AUDIO_VOICE_MIN_LEVEL=16

# Maximum file sizes (in bytes) - can be adjusted
# MAX_IMAGE_SIZE=10485760       # 10MB
# MAX_VIDEO_SIZE=104857600      # 100MB
# MAX_AUDIO_SIZE=52428800       # 50MB
# MAX_DOCUMENT_SIZE=20971520    # 20MB

# ==================== AI/LLM CONFIGURATION ====================
# For AI-powered features (test generation, performance insights)
# Supports OpenAI or Anthropic
LLM_PROVIDER="anthropic"
# LLM API key removed from repository for security. Set this in your environment.
LLM_API_KEY="your-api-key"

# Zoho recommendation for organization/custom-domain mailboxes:
# SMTP_HOST=smtppro.zoho.com
# ZOHO_DATA_CENTER=us
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_REQUIRE_TLS=false
# For AU data center:
# ZOHO_DATA_CENTER=au
# SMTP_HOST=smtppro.zoho.com.au
# For personal @zoho accounts, prefer:
# SMTP_HOST=smtp.zoho.com
# ZOHO_ACCOUNT_TYPE=personal

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=
SMTP_REQUIRE_TLS=
ZOHO_ACCOUNT_TYPE=organization
ZOHO_DATA_CENTER=us

# ==================== FILE STORAGE ====================
# Files (snapshots, recordings, MCQ media, ID documents) are stored in PostgreSQL
# No external storage service required!
# For large-scale deployments with heavy video recording, consider adding
# DigitalOcean Spaces or AWS S3 later

# Maximum file sizes (in bytes) - can be adjusted
# MAX_IMAGE_SIZE=10485760       # 10MB
# MAX_VIDEO_SIZE=104857600      # 100MB
# MAX_AUDIO_SIZE=52428800       # 50MB
# MAX_DOCUMENT_SIZE=20971520    # 20MB

# ==================== AI/LLM CONFIGURATION ====================
# For AI-powered features (test generation, performance insights)
# Supports OpenAI or Anthropic
LLM_PROVIDER="anthropic"  # or "openai"
LLM_API_KEY="your-api-key"

# Optional: Specific API keys if using both providers
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ==================== PROCTORING SETTINGS ====================
# Default proctoring configuration
DEFAULT_MAX_VIOLATIONS=5
FACE_DETECTION_INTERVAL_MS=2000
SNAPSHOT_INTERVAL_MS=30000
RECORDING_CHUNK_SIZE_MS=10000

# ==================== ID VERIFICATION ====================
# For production, integrate with verification services
# AWS Rekognition, Azure Face API, or third-party (Jumio, Onfido)
# VERIFICATION_PROVIDER="aws"  # aws, azure, jumio, onfido
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-aws-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret"
# ==================== ID VERIFICATION ====================
# Provider used by backend/src/services/verificationService.ts
VERIFICATION_PROVIDER="compreface"
COMPREFACE_BASE_URL="http://165.22.216.208:8000"
COMPREFACE_API_KEY="0e4f2d01-31c7-4ccb-888d-7ee9833f97df"
COMPREFACE_DET_PROB_THRESHOLD=0.9
VERIFICATION_FACE_MATCH_THRESHOLD=85

PYTHON_CV_SERVICE_URL=http://localhost:8010
PROCTOR_TRACE=true
PYTHON_CV_TIMEOUT_MS=3500
PYTHON_CV_RETRY_COUNT=0
PYTHON_CV_RETRY_DELAY_MS=200
PYTHON_CV_CIRCUIT_FAILURES=8
PYTHON_CV_CIRCUIT_OPEN_MS=30000

PROCTOR_AUTO_FLAG_ON_CRITICAL=false
PROCTOR_SESSION_MIN_INTERVAL_MS=3000
PROCTOR_MAX_CONCURRENT_ANALYSIS=140
PROCTOR_MAX_CONCURRENT_RECORDING_UPLOADS=30
PROCTOR_ALLOWED_EVENTS=multiple_faces,phone_detected,face_not_detected,voice_detected,tab_switch,fullscreen_exit,window_blur,copy_paste_attempt,devtools_open,camera_blocked,looking_away,suspicious_audio,unauthorized_object_detected
PROCTOR_REPORT_EVENTS=phone_detected,multiple_faces,looking_away,voice_detected,suspicious_audio,unauthorized_object_detected
PROCTOR_ENGINE_API_KEY=change-me-engine-key
